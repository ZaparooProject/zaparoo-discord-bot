# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Discord Role ID for authorized users (can use bot + messages included in context)
# Right-click the role in Server Settings -> Roles -> Copy Role ID (enable Developer Mode first)
AUTHORIZED_ROLE_ID=your_discord_role_id

# GitHub Authentication (choose ONE method)
#
# Option 1: Personal Access Token (issues created as you)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token
#
# Option 2: GitHub App (issues created as bot) - set all three:
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
# GITHUB_APP_INSTALLATION_ID=12345678

# OpenAI API Key (for generating issue titles)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# File hosting - files saved locally, served by nginx or similar
# IMAGES_DIR: Local directory to save downloaded files
# IMAGES_URL: Public URL where files will be accessible (served by nginx)
IMAGES_DIR=./images
IMAGES_URL=https://your-server.com/discord-files

# Number of previous messages to include as context (default: 5)
CONTEXT_MESSAGES=5

# How long to wait for second reaction in two-step flow (seconds)
PENDING_TIMEOUT=60

# Max attachment size in bytes (default: 10MB)
# MAX_ATTACHMENT_SIZE=10485760

# OpenAI model for title generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Path to config file (default: ./config.toml)
# CONFIG_PATH=./config.toml
