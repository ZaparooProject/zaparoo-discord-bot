# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Google Gemini API Key (for generating issue titles and smart features)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Discord role ID for authorized users
# Right-click the role in Server Settings -> Roles -> Copy Role ID (enable Developer Mode first)
AUTHORIZED_ROLE_ID=0

# GitHub auth: set EITHER a personal token OR all three App variables
# Personal token: https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_token

# GitHub App auth (issues created as bot):
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
# GITHUB_APP_INSTALLATION_ID=12345678

# Public URL where downloaded files are served (by nginx or similar)
# IMAGES_URL=https://your-server.com/discord-files
